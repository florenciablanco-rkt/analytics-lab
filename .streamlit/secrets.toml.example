# Copiá este archivo a .streamlit/secrets.toml y completá con credenciales reales.
# NO commitear secrets.toml (está en .gitignore).
# En Streamlit Community Cloud, cargá estos valores en Settings → Secrets.

[athena]
aws_access_key_id     = "AKIA..."
aws_secret_access_key = "..."
region_name           = "us-east-1"
s3_staging_dir        = "s3://TU-BUCKET/athena-results/"
work_group            = "primary"          # opcional
